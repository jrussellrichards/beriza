NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=berisa_db
DB_USER=berisa_user
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DATABASE_URL=postgresql://berisa_user:password@localhost:5432/berisa_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here_change_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=1000
S3_BUCKET=berisa-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_FROM=noreply@berisa.com
EMAIL_FROM_NAME=BERISA Intelligence
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PROFESIONAL=price_profesional_id
STRIPE_PRICE_BUSINESS=price_business_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id
SCRAPER_ENABLED=false
SCRAPER_CRON_SEIA=0 6 * * *
SCRAPER_CRON_MOP=0 7 * * *
SCRAPER_CRON_CBC=0 8 * * *
GEOCODER_API_KEY=your_google_maps_key
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.berisa.com
LOG_LEVEL=info
