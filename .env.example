# Copia este archivo como .env y genera secretos reales con:
#   cd backend && npm run create-env
NODE_ENV=development
PORT=8080
POSTGRES_DB=berisa
POSTGRES_USER=berisa_app
POSTGRES_PASSWORD=<generar_password_fuerte>
DATABASE_URL=postgres://berisa_app:<generar_password_fuerte>@localhost:5432/berisa
JWT_SECRET=<generar_hex_64_o_mas_caracteres>
JWT_EXPIRES_IN=8h
SESSION_COOKIE_NAME=berisa_session
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
ADMIN_EMAIL=<correo_admin>
ADMIN_PASSWORD=<generar_password_admin_fuerte>
ADMIN_NAME=Administrador Berisa
PII_ENCRYPTION_KEY=<generar_64_hex_32_bytes>
ALERT_WEBHOOK_SECRET=<generar_secreto_webhook>
EMAIL_PROVIDER_URL=
EMAIL_PROVIDER_TOKEN=
WORKER_INTERVAL_MINUTES=30
API_KEY_PREFIX=brs_live
