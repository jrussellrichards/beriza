# Base de datos
DATABASE_URL=postgresql://acredita:acredita@localhost:5432/acredita

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# IA
VISION_LLM_API_KEY=
VISION_LLM_MODEL=

# Storage (local en dev; en prod usa Cloudflare R2 vía la API compatible con S3)
FILE_STORAGE=local
LOCAL_STORAGE_PATH=uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Email
RESEND_API_KEY=
EMAIL_FROM=Acredita <onboarding@resend.dev>

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000
